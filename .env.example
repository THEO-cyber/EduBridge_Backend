# ─── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development                   # development | production
SWAGGER_ENABLED=true                   # expose /api/docs in production

# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000,http://localhost:19006

# ─── Database (PostgreSQL via Prisma) ─────────────────────────────────────────
# Use a pooled URL for the app and a direct URL for Prisma migrations
DATABASE_URL=postgresql://user:password@localhost:5432/edubridge?schema=public
DIRECT_URL=postgresql://user:password@localhost:5432/edubridge?schema=public

# ─── Redis (BullMQ job queues) ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false                        # true for Upstash / managed Redis with TLS

# ─── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── S3-compatible storage (AWS S3 or MinIO via Docker) ───────────────────────
# MinIO (Docker, self-hosted — FREE):
#   S3_ENDPOINT=http://localhost:9000     ← set this to use MinIO
#   AWS_ACCESS_KEY_ID=minioadmin          ← MinIO root user
#   AWS_SECRET_ACCESS_KEY=minioadmin      ← MinIO root password
#   AWS_S3_BUCKET=edubridge-videos
#   AWS_REGION=us-east-1
#
# AWS S3 (cloud):
#   Leave S3_ENDPOINT blank — SDK auto-routes to AWS
#   AWS_ACCESS_KEY_ID=your-access-key-id
#   AWS_SECRET_ACCESS_KEY=your-secret-access-key
#   AWS_REGION=us-east-1
#   AWS_S3_BUCKET=edubridge-videos
#   AWS_CLOUDFRONT_DOMAIN=d1abc123xyz.cloudfront.net   ← optional CDN

S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_S3_BUCKET=edubridge-videos
# AWS_CLOUDFRONT_DOMAIN=d1abc123xyz.cloudfront.net

# ─── Stripe (payments) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe dashboard → Developers → Webhooks

# ─── LiveKit (live 1-on-1 sessions) ──────────────────────────────────────────
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
# For Gmail use an App Password (myaccount.google.com → Security → App passwords)
EMAIL_PASS=your-app-password
EMAIL_FROM=EduBridge <noreply@edubridge.com>



# ─── Firebase (FCM push notifications) ───────────────────────────────────────
# Option A — point to the downloaded service-account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option B — paste the individual fields (easier for CI/cloud env vars)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key value; \n will be replaced with real newlines at runtime
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ─── File uploads ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE=104857600                # 100 MB for images/docs. Videos use a 2 GB hard limit.
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
ALLOWED_VIDEO_TYPES=mp4,avi,mov,wmv,mkv,webm
ALLOWED_DOCUMENT_TYPES=pdf,doc,docx,ppt,pptx

# ─── Sentry (error tracking + performance monitoring) ─────────────────────────
# Leave blank in development to disable Sentry. Required in production.
SENTRY_DSN=
# Semantic version tag attached to Sentry releases (e.g. 1.2.3)
APP_VERSION=1.0.0

# ─── Stripe Connect (instructor payouts) ──────────────────────────────────────
# Used by the Payouts module for instructor onboarding and fund transfers.
# Same STRIPE_SECRET_KEY above is re-used; no additional keys needed.
# Set the frontend URL that Stripe redirects to after Connect onboarding:
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/dashboard/payouts/refresh
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/dashboard/payouts/return

# ─── Logging ──────────────────────────────────────────────────────────────────
# Override the minimum log level (debug | info | warn | error). Defaults to
# "debug" in development and "info" in production.
# LOG_LEVEL=info

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Configured in app.module.ts (10/s burst, 200/min per IP). Override as needed.

# ─── Pagination defaults ──────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
